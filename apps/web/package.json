{
	"name": "@pathistics/web",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:report": "eslint . --format json --output-file lint-report.json || true",
		"preview": "vite preview",
		"test": "vitest",
		"test:unit": "vitest run unit.test.ts --passWithNoTests",
		"test:integration": "vitest run integration.test.ts --passWithNoTests",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@fontsource/manrope": "^5.2.8",
		"@fontsource/sen": "^5.2.8",
		"@hookform/resolvers": "^5.4.0",
		"@mui/icons-material": "^9.1.0",
		"@mui/material": "^9.1.0",
		"@types/leaflet": "^1.9.21",
		"axios": "^1.17.0",
		"date-fns": "^4.4.0",
		"html2canvas": "^1.4.1",
		"leaflet": "^1.9.4",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-hook-form": "^7.78.0",
		"react-leaflet": "^5.0.0",
		"react-router": "^7.17.0",
		"recharts": "^3.8.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@pathistics/eslint-config": "workspace:*",
		"@pathistics/tsconfig": "workspace:*",
		"@rolldown/plugin-babel": "^0.2.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/babel__core": "^7.20.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.8",
		"@vitest/ui": "^4.1.8",
		"babel-plugin-react-compiler": "^1.0.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"vite": "^8.0.12",
		"vitest": "^4.1.8"
	}
}
