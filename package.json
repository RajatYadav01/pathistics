{
	"name": "pathistics",
	"version": "0.0.0",
	"private": true,
	"license": "BSD-3-Clause",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"author": "Rajat Yadav",
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --build",
		"lint": "turbo run lint",
		"lint:fix": "turbo run lint:fix",
		"lint:report": "turbo run lint:report",
		"test": "turbo run test",
		"test:unit": "turbo run test:unit",
		"test:integration": "turbo run test:integration",
		"test:api": "turbo run test --filter=@pathistics/api",
		"test:api:unit": "turbo run test:unit --filter=@pathistics/api",
		"test:api:integration": "turbo run test:integration --filter=@pathistics/api",
		"test:web": "turbo run test --filter=@pathistics/web",
		"test:web:unit": "turbo run test:unit --filter=@pathistics/web",
		"test:web:integration": "turbo run test:integration --filter=@pathistics/web",
		"test:watch": "turbo run test:watch",
		"test:coverage": "turbo run test:coverage",
		"test:e2e": "turbo run test:e2e --filter=@pathistics/e2e-tests",
		"test:e2e:ui": "turbo run test:e2e -- --ui",
		"dev": "turbo run dev --parallel",
		"dev:api": "turbo run dev --filter=@pathistics/api",
		"dev:web": "turbo run dev --filter=@pathistics/web -- --host",
		"build:web": "turbo run build --filter=@pathistics/web",
		"conflicts": "syncpack lint --dependency-types prod,dev",
		"conflicts:fix": "syncpack fix --dependency-types prod,dev",
		"prepare": "husky",
		"lint-staged": "lint-staged"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.9.1",
		"eslint": "^10.4.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-turbo": "^2.9.14",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"prettier": "^3.8.3",
		"syncpack": "^15.3.1",
		"turbo": "^2.9.14",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0"
	},
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
